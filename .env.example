# === LLM Providers ===
# Gemini (obrigatório - modelo principal)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (opcional - fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (opcional - fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/zap_agent
VECTOR_DATABASE_URL=postgresql://user:password@localhost:5432/zap_vectors

# === WhatsApp ===
# ID do dono do bot (será preenchido automaticamente no primeiro uso)
OWNER_PHONE=

# === Agent ===
AGENT_NAME=Jarvis
AGENT_LANGUAGE=pt-BR
MAX_MEMORY_ITEMS=1000
CONVERSATION_HISTORY_LIMIT=20
